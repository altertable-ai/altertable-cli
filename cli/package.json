{
  "name": "@altertable/cli",
  "version": "1.1.0",
  "description": "Altertable CLI — query and manage your data platform",
  "homepage": "https://github.com/altertable-ai/altertable-cli#readme",
  "bugs": {
    "url": "https://github.com/altertable-ai/altertable-cli/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/altertable-ai/altertable-cli.git",
    "directory": "cli"
  },
  "bin": {
    "altertable": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "generate": "bun run scripts/generate-openapi-types.ts && bun run scripts/generate-openapi-index.ts",
    "spec:refresh": "curl -fsSL https://app.altertable.ai/rest/v1/openapi.yaml -o openapi/openapi.yaml && bun run generate && oxfmt openapi/openapi.yaml",
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "pack:check": "bun run build && bun pm pack --dry-run",
    "knip": "knip"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "citty": "0.2.2",
    "oauth4webapi": "3.8.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "knip": "6.25.0",
    "openapi-typescript": "7.13.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.9"
}
